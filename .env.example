# Copy to .env and fill in. .env is gitignored and auto-loaded from the working
# directory at startup (no need to `source` it). Real shell exports take priority.
#   cp .env.example .env

# Go module proxy (optional; used by `docker compose build` variable substitution).
# Docker abroad (default): goproxy.io — leave unset
# GOPROXY=https://goproxy.io,direct
# Host `go build` abroad: go env -w GOPROXY=https://proxy.golang.org,direct
# China Docker: add -f docker-compose.cn.yml or GOPROXY=https://goproxy.cn,direct
# Redis rate limiting: add -f docker-compose.redis.yml (off by default, like go run)

# --- Gemini Live (working) ---
# Google AI Studio key. GOOGLE_API_KEY also works.
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the Live model (default models/gemini-3.1-flash-live-preview).
# Must support bidiGenerateContent. List yours with:
#   curl ".../v1beta/models?key=$KEY&pageSize=200" | jq '.models[]
#     | select(.supportedGenerationMethods[]?=="bidiGenerateContent").name'
# GEMINI_MODEL=models/gemini-2.5-flash-native-audio-latest

# --- Doubao / Volcengine 端到端实时语音 ---
# DOUBAO_APP_ID=your-app-id
# DOUBAO_ACCESS_TOKEN=your-access-token

# --- Cascade stack (docker-compose.cascade.yml) ---
# PUBLIC_IP=<host IP reachable from browser — required for WebRTC>
# QWEN_MODEL_PATH=/path/to/Qwen3.5-9B   # optional; default mounts WebHarness cache
